.lineup-detail-page {
  padding-bottom: 72rpx;
}

.detail-card {
  min-height: 248rpx;
  padding: 34rpx 32rpx;
  background: rgba(78, 88, 99, 0.76);
}

.detail-title {
  color: #fff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.2;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.detail-rating {
  margin-top: 22rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: rgba(5, 10, 15, 0.26);
}

.detail-rating-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.rating-stars,
.rate-stars {
  display: flex;
  align-items: center;
  gap: 3rpx;
}

.rating-star {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  overflow: hidden;
  flex: 0 0 auto;
}

.rating-star-base,
.rating-star-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 28rpx;
  line-height: 28rpx;
  font-size: 28rpx;
}

.rating-star-base {
  color: rgba(255, 255, 255, 0.25);
}

.rating-star-fill {
  width: 0;
  overflow: hidden;
  color: #ffd166;
}

.detail-rating-score {
  color: #ffd166;
  font-size: 26rpx;
  font-weight: 900;
}

.detail-rating-count,
.rate-label {
  color: #aab5c3;
  font-size: 22rpx;
}

.rate-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.rate-star {
  color: rgba(255, 255, 255, 0.28);
  font-size: 30rpx;
  line-height: 30rpx;
}

.rate-star-active {
  color: #ffd166;
}

.detail-tag {
  min-width: 116rpx;
  height: 46rpx;
  border-radius: 6rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.tag-agent {
  color: #ff747b;
  background: rgba(255, 70, 85, 0.22);
}

.tag-map {
  color: #12cda0;
  background: rgba(18, 205, 160, 0.18);
}

.tag-category {
  color: #fff;
  background: rgba(255, 255, 255, 0.16);
}

.tag-side {
  color: #ff6471;
  background: rgba(255, 70, 85, 0.16);
}

.detail-desc {
  margin-top: 22rpx;
  color: #c5cfdb;
  font-size: 26rpx;
  line-height: 1.48;
}

.section-gap {
  margin-top: 52rpx;
}

.stand-card {
  position: relative;
  height: 392rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-left: 10rpx solid #ff4655;
  background: linear-gradient(180deg, #102033, #071018);
}

.stand-swiper {
  width: 100%;
  height: 100%;
}

.stand-image,
.aim-image,
.effect-image,
.effect-video {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0.32;
}

.effect-video {
  opacity: 0.72;
}

.placeholder-word {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  z-index: 2;
  color: rgba(255, 255, 255, 0.62);
  font-size: 34rpx;
  text-align: center;
  transform: translateY(-50%);
}

.multi-badge {
  position: absolute;
  right: 28rpx;
  top: 24rpx;
  z-index: 3;
  height: 52rpx;
  border-radius: 8rpx;
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: rgba(5, 10, 15, 0.58);
  font-size: 24rpx;
}

.stand-label,
.stand-count {
  position: absolute;
  left: 20rpx;
  bottom: 24rpx;
  z-index: 3;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
}

.stand-count {
  left: 0;
  right: 0;
  bottom: 22rpx;
  padding-left: 20rpx;
}

.stand-label {
  bottom: 58rpx;
}

.media-note {
  margin-top: 18rpx;
  color: #9aa6b5;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
}

.aim-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 22rpx;
}

.aim-track {
  display: inline-flex;
  gap: 20rpx;
}

.aim-card {
  position: relative;
  width: 330rpx;
  height: 188rpx;
  overflow: hidden;
  border-left: 8rpx solid #ff4655;
  display: inline-flex;
  background: linear-gradient(180deg, #102033, #071018);
}

.aim-word {
  font-size: 24rpx;
}

.aim-title {
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
  z-index: 3;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.effect-card {
  position: relative;
  height: 216rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-left: 10rpx solid #ff4655;
  background: linear-gradient(180deg, #102033, #071018);
}

.effect-word {
  font-size: 34rpx;
}

.effect-type {
  position: absolute;
  right: 44rpx;
  top: 22rpx;
  z-index: 3;
  min-width: 82rpx;
  height: 52rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: rgba(255, 70, 85, 0.42);
  font-size: 24rpx;
  font-weight: 800;
}

.play-button {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 4;
  width: 86rpx;
  height: 86rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.58);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: rgba(5, 10, 15, 0.42);
  font-size: 38rpx;
  transform: translate(-50%, -50%);
}

.effect-title {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  z-index: 3;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}
