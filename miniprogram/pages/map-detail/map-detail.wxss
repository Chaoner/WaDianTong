.map-detail-page {
  padding-bottom: 70rpx;
}

.tactical-board {
  position: relative;
  height: 33vh;
  min-height: 408rpx;
  max-height: 472rpx;
  margin-top: 18rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(28, 41, 52, 0.96), rgba(8, 16, 24, 0.98)),
    #101923;
}

.tactical-board::after {
  position: absolute;
  left: 28%;
  right: 26%;
  bottom: 112rpx;
  height: 124rpx;
  border: 6rpx solid rgba(18, 205, 160, 0.9);
  border-top: 0;
  content: "";
}

.tactical-map {
  position: absolute;
  left: 5%;
  top: 4%;
  z-index: 1;
  width: 90%;
  height: 90%;
  display: block;
}

.map-side-tag {
  position: absolute;
  top: 50%;
  z-index: 3;
  min-width: 104rpx;
  height: 42rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(5, 10, 15, 0.68);
  font-size: 22rpx;
  font-weight: 800;
  transform: translateY(-50%);
}

.map-side-defense {
  left: 18rpx;
  border: 2rpx solid rgba(18, 205, 160, 0.86);
  color: #12cda0;
}

.map-side-attack {
  right: 18rpx;
  border: 2rpx solid rgba(255, 70, 85, 0.86);
  color: #ff4655;
}

.side-switch {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.side-button {
  height: 72rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
}

.side-defense {
  border: 2rpx solid #12cda0;
  color: #12cda0;
  background: rgba(18, 205, 160, 0.12);
}

.side-attack {
  border: 2rpx solid #ff4655;
  color: #ff4655;
  background: rgba(255, 70, 85, 0.12);
}

.side-defense.side-button-active {
  color: #061016;
  background: #12cda0;
}

.side-attack.side-button-active {
  color: #fff;
  background: #ff4655;
}

.current-summary {
  margin: 16rpx 0 0 4rpx;
  color: #8b96a4;
  font-size: 24rpx;
}

.role-tabs {
  width: 100%;
  gap: 12rpx;
  margin-top: 28rpx;
  display: flex;
  align-items: stretch;
  overflow: hidden;
}

.role-option {
  width: calc(20vw - 59.2rpx);
  min-width: calc(20vw - 59.2rpx);
  height: calc(20vw - 59.2rpx);
  display: flex;
  align-items: stretch;
  flex: 0 0 auto;
  overflow: hidden;
  transition: width 220ms ease;
}

.role-option-active {
  width: calc(20vw + 132.8rpx);
}

.role-chip {
  width: calc(20vw - 59.2rpx);
  min-width: calc(20vw - 59.2rpx);
  height: calc(20vw - 59.2rpx);
  flex: 0 0 auto;
  padding: 0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #dce3ea;
  background: rgba(255, 255, 255, 0.12);
}

.role-chip-active {
  color: #fff;
  background: #df4040;
}

.role-name-panel {
  width: 0;
  height: 100%;
  margin-left: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  overflow: hidden;
  opacity: 0;
  color: #f4f7fb;
  background: rgba(78, 88, 99, 0.86);
  transition: width 220ms ease, margin-left 220ms ease, opacity 150ms ease;
}

.role-option-active .role-name-panel {
  width: 180rpx;
  margin-left: 12rpx;
  opacity: 1;
}

.role-name-text {
  min-width: 140rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
}

.role-chip-icon-wrap {
  width: 60%;
  height: 60%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.role-chip-icon {
  width: 100%;
  height: 100%;
  display: block;
}

.role-all-icon {
  width: 48%;
  height: 48%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 6rpx;
}

.role-all-icon view {
  width: 100%;
  height: 100%;
  border-radius: 2rpx;
  background: #fff;
}

.role-title {
  margin-top: 46rpx;
}

.agent-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 22rpx;
}

.agent-card {
  position: relative;
  height: 208rpx;
  padding: 0;
  overflow: hidden;
  text-align: center;
  background: linear-gradient(180deg, #2e3a48 0%, #8d2f2b 100%);
}

.agent-avatar {
  width: 100%;
  height: 100%;
  border: 0;
  border-radius: 0;
  margin: 0;
  display: block;
  transform: translateY(-14rpx);
  background: transparent;
}

.agent-name {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 52rpx;
  margin-top: 0;
  padding-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f4f7fb;
  background: linear-gradient(180deg, rgba(6, 11, 17, 0) 0%, rgba(6, 11, 17, 0.82) 34%, rgba(6, 11, 17, 0.96) 100%);
  font-size: 26rpx;
  font-weight: 700;
}

.agent-role {
  display: none;
}

.section-note {
  margin: 24rpx 0 0 4rpx;
  color: #7f8a99;
  font-size: 24rpx;
}
