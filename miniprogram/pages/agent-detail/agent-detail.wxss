.agent-detail-root {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #081018;
}

.agent-bg-portrait {
  position: fixed;
  right: -80rpx;
  bottom: 16vh;
  z-index: 0;
  width: 720rpx;
  height: 920rpx;
  opacity: 0.2;
  filter: blur(12rpx);
  transform: scale(1.18);
}

.agent-detail-page {
  position: relative;
  z-index: 1;
  padding-bottom: 72rpx;
  background:
    radial-gradient(circle at 24% 0%, rgba(255, 75, 72, 0.16), transparent 30%),
    linear-gradient(180deg, rgba(14, 23, 33, 0.96) 0%, rgba(8, 16, 24, 0.86) 48%, rgba(7, 13, 20, 0.94) 100%);
}

.agent-hero {
  position: relative;
  min-height: 232rpx;
  padding: 34rpx 36rpx 32rpx 276rpx;
  overflow: hidden;
  background: rgba(78, 88, 99, 0.76);
}

.agent-hero-portrait {
  position: absolute;
  left: 48rpx;
  bottom: -2rpx;
  width: 238rpx;
  height: 280rpx;
  display: block;
}

.agent-hero-info {
  min-height: 166rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.agent-name {
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
}

.agent-role {
  width: 122rpx;
  height: 48rpx;
  margin-top: 14rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff747b;
  background: rgba(255, 70, 85, 0.22);
  font-size: 24rpx;
  font-weight: 800;
}

.agent-desc {
  margin-top: 16rpx;
  color: #c5cfdb;
  font-size: 24rpx;
  line-height: 1.38;
}

.skill-title {
  margin-top: 40rpx;
}

.ability-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 20rpx;
}

.ability-track {
  display: inline-flex;
  align-items: stretch;
  gap: 12rpx;
  min-width: 100%;
}

.ability-button {
  width: 84rpx;
  height: 84rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  background: rgba(255, 255, 255, 0.2);
}

.ability-active {
  background: #ff4655;
}

.ability-icon {
  width: 52rpx;
  height: 52rpx;
  display: block;
}

.ability-desc {
  width: 340rpx;
  height: 84rpx;
  padding: 14rpx 22rpx;
  flex: 0 0 auto;
  background: rgba(78, 88, 99, 0.86);
}

.ability-name {
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.ability-text {
  margin-top: 6rpx;
  color: #c5cfdb;
  font-size: 21rpx;
  line-height: 1.25;
  white-space: normal;
}

.map-title,
.filter-title,
.lineup-title {
  margin-top: 44rpx;
}

.map-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 20rpx;
}

.map-track {
  display: inline-flex;
  gap: 18rpx;
}

.map-option {
  position: relative;
  width: 220rpx;
  height: 112rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 8rpx;
  overflow: hidden;
  display: inline-flex;
  background: #101923;
}

.map-option-active {
  border-color: #ff4655;
}

.map-image {
  width: 100%;
  height: 100%;
  display: block;
  opacity: 0.78;
}

.map-name {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(180deg, rgba(5, 10, 15, 0), rgba(5, 10, 15, 0.86));
  font-size: 23rpx;
  font-weight: 800;
}

.section-note {
  margin-top: 14rpx;
  color: #8b96a4;
  font-size: 23rpx;
}

.side-filter {
  margin-top: 22rpx;
  padding: 6rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  background: rgba(255, 255, 255, 0.07);
}

.side-option {
  height: 62rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8792a1;
  font-size: 24rpx;
  font-weight: 800;
}

.side-option-active {
  color: #fff;
  background: #4e5863;
}

.side-option-defense.side-option-active {
  color: #061016;
  background: #12cda0;
}

.side-option-attack.side-option-active {
  color: #fff;
  background: #ff4655;
}

.filter-row {
  display: grid;
  grid-template-columns: 1fr 176rpx;
  gap: 16rpx;
  margin-top: 20rpx;
}

.category-select {
  height: 70rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #f4f7fb;
  background: rgba(78, 88, 99, 0.88);
  font-size: 25rpx;
  font-weight: 800;
}

.select-arrow {
  color: #aab5c3;
  font-size: 34rpx;
}

.apply-button {
  height: 70rpx;
  border: 1rpx solid rgba(255, 70, 85, 0.82);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff747b;
  background: rgba(255, 70, 85, 0.14);
  font-size: 24rpx;
  font-weight: 800;
}

.lineup-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.lineup-card {
  position: relative;
  min-height: 124rpx;
  padding: 24rpx 18rpx;
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  background: rgba(78, 88, 99, 0.78);
}

.lineup-cover {
  width: 158rpx;
  height: 104rpx;
  border-radius: 6rpx;
  display: block;
  background: #0c1722;
}

.lineup-info {
  flex: 1;
  min-width: 0;
}

.lineup-name {
  color: #fff;
  font-size: 27rpx;
  font-weight: 800;
}

.lineup-meta {
  margin-top: 12rpx;
  color: #aab5c3;
  font-size: 23rpx;
}

.lineup-rating-count {
  margin-top: 8rpx;
  color: #7f8a99;
  font-size: 21rpx;
}

.lineup-state {
  min-width: 78rpx;
  height: 44rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #12cda0;
  background: rgba(18, 205, 160, 0.16);
  font-size: 22rpx;
  font-weight: 800;
}

.lineup-rating {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rating-stars {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.rating-star {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  line-height: 24rpx;
  overflow: hidden;
  flex: 0 0 auto;
}

.rating-star-base,
.rating-star-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 24rpx;
  line-height: 24rpx;
  font-size: 24rpx;
}

.rating-star-base {
  color: rgba(255, 255, 255, 0.25);
}

.rating-star-fill {
  width: 0;
  overflow: hidden;
  color: #ffd166;
}

.rating-score {
  color: #ffd166;
  font-size: 22rpx;
  font-weight: 800;
}

.empty-card {
  height: 120rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b96a4;
  background: rgba(78, 88, 99, 0.68);
  font-size: 25rpx;
}
