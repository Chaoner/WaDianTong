.profile-page {
  padding-bottom: 72rpx;
}

.profile-card {
  position: relative;
  min-height: 154rpx;
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: rgba(78, 88, 99, 0.78);
}

.profile-arrow {
  color: #8f9aaa;
  font-size: 48rpx;
  line-height: 1;
}

.avatar {
  width: 106rpx;
  height: 106rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: #ff4655;
  font-size: 42rpx;
  font-weight: 900;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #fff;
  font-size: 34rpx;
  font-weight: 900;
}

.profile-desc {
  margin-top: 8rpx;
  color: #b6c0cc;
  font-size: 24rpx;
  line-height: 1.3;
}

.stat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 32rpx;
}

.stat-card {
  height: 128rpx;
  padding: 22rpx 24rpx;
  background: rgba(38, 48, 58, 0.9);
}

.stat-num {
  color: #fff;
  font-size: 40rpx;
  font-weight: 900;
}

.stat-label {
  margin-top: 12rpx;
  color: #aab5c3;
  font-size: 23rpx;
}

.add-lineup-button {
  height: 122rpx;
  margin-top: 32rpx;
  border-radius: 8rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  color: #fff;
  background: #ff4655;
}

.add-icon {
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 900;
}

.add-copy {
  flex: 1;
  min-width: 0;
}

.add-title {
  font-size: 33rpx;
  font-weight: 900;
}

.add-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.add-arrow,
.menu-arrow {
  color: rgba(255, 255, 255, 0.55);
  font-size: 48rpx;
  line-height: 1;
}

.menu-title {
  margin-top: 44rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.menu-row {
  min-height: 86rpx;
  padding: 16rpx 20rpx 16rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(38, 48, 58, 0.9);
}

.menu-copy {
  flex: 1;
  min-width: 0;
}

.menu-name {
  color: #fff;
  font-size: 29rpx;
  font-weight: 900;
}

.menu-desc {
  margin-top: 6rpx;
  color: #8f9aaa;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-count {
  min-width: 54rpx;
  height: 36rpx;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #12cda0;
  background: rgba(18, 205, 160, 0.12);
  font-size: 21rpx;
  font-weight: 900;
}

.recent-title {
  margin-top: 42rpx;
}

.recent-card {
  min-height: 108rpx;
  margin-top: 22rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  background: rgba(38, 48, 58, 0.9);
}

.recent-thumb {
  width: 128rpx;
  height: 76rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #102033, #071018);
}

.recent-info {
  flex: 1;
  min-width: 0;
}

.recent-name {
  color: #fff;
  font-size: 27rpx;
  font-weight: 900;
}

.recent-meta {
  margin-top: 10rpx;
  color: #8f9aaa;
  font-size: 22rpx;
}

.recent-rating {
  color: #ffd166;
  font-size: 22rpx;
  font-weight: 900;
}
