.profile-card {
  min-height: 150rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #465263, #101822);
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 700;
}

.profile-meta {
  margin-top: 10rpx;
  color: #8792a1;
  font-size: 24rpx;
}

.stats {
  margin-top: 22rpx;
  padding: 22rpx 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.stat-item {
  text-align: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item:last-child {
  border-right: none;
}

.stat-num {
  color: #fff;
  font-size: 38rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 6rpx;
  color: #8792a1;
  font-size: 22rpx;
}

.menu {
  margin-top: 36rpx;
  overflow: hidden;
}

.menu-row {
  height: 92rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #dfe6ed;
  font-size: 28rpx;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-row text {
  color: #8792a1;
  font-size: 42rpx;
}
