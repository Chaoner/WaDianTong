<view class="page-shell">
  <view class="page-title">点位筛选</view>
  <view class="search-box">搜索地图 / 角色 / 点位</view>

  <view class="filter-row">
    <view class="filter-select card">地图：源工重镇</view>
    <view class="filter-select card">角色：炼狱</view>
  </view>

  <view class="side-switch card">
    <view
      class="side-item {{selectedSide === item ? 'side-active' : ''}}"
      wx:for="{{sides}}"
      wx:key="*this"
      data-side="{{item}}"
      bindtap="onSideTap"
    >
      {{item}}
    </view>
  </view>

  <scroll-view class="area-tabs" scroll-x>
    <view
      class="tag {{selectedArea === item ? 'tag-active' : ''}}"
      wx:for="{{areas}}"
      wx:key="*this"
      data-area="{{item}}"
      bindtap="onAreaTap"
    >
      {{item}}
    </view>
  </scroll-view>

  <view class="lineup-list">
    <view
      class="lineup-card card"
      wx:for="{{lineups}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onLineupTap"
    >
      <view class="lineup-icon">◆</view>
      <view class="lineup-info">
        <view class="lineup-title">{{item.title}}</view>
        <view class="lineup-desc">{{item.desc}}</view>
      </view>
      <view class="difficulty">{{item.difficulty}}</view>
    </view>
  </view>
</view>
