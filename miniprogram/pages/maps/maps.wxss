.map-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 28rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  color: #eef3f8;
  font-size: 26rpx;
}

.map-row {
  position: relative;
  height: 176rpx;
  padding: 0;
  overflow: hidden;
  background: #071018;
}

.map-cover {
  width: 100%;
  height: 100%;
  border-radius: 0;
  background: linear-gradient(135deg, #3b4858, #121b25 58%, #ff4b48);
  display: block;
}

.map-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 56rpx;
  padding: 10rpx 128rpx 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  background: linear-gradient(180deg, rgba(6, 11, 17, 0) 0%, rgba(6, 11, 17, 0.82) 34%, rgba(6, 11, 17, 0.96) 100%);
}

.map-name {
  color: #f4f7fb;
  font-size: 28rpx;
  font-weight: 700;
}

.map-meta {
  display: none;
}

.map-mode {
  position: absolute;
  right: 24rpx;
  top: 50%;
  min-width: 84rpx;
  height: 44rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f4f7fb;
  background: rgba(6, 11, 17, 0.62);
  font-size: 24rpx;
  font-weight: 700;
  transform: translateY(-50%);
}

.map-mode-competitive {
  border-color: rgba(255, 70, 85, 0.78);
  color: #ff6471;
  background: rgba(255, 70, 85, 0.16);
}

.map-mode-normal {
  border-color: rgba(18, 205, 160, 0.72);
  color: #12cda0;
  background: rgba(18, 205, 160, 0.12);
}

.empty-card {
  height: 150rpx;
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8f9aaa;
  background: rgba(78, 88, 99, 0.68);
  font-size: 25rpx;
}
