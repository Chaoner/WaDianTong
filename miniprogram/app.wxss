/**app.wxss**/
page {
  min-height: 100vh;
  background: #081018;
  color: #eef3f8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
}

view,
text,
input,
button,
image,
scroll-view {
  box-sizing: border-box;
}

button {
  background: initial;
  padding: 0;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(255, 75, 72, 0.14), transparent 30%),
    linear-gradient(180deg, #0e1721 0%, #081018 42%, #070d14 100%);
}

.page-title {
  margin: 12rpx 0 26rpx;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 36rpx 0 18rpx;
}

.section-title {
  position: relative;
  padding-left: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.section-title::before {
  position: absolute;
  left: 0;
  top: 6rpx;
  width: 6rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: #ff4b48;
  content: "";
}

.section-more {
  color: #8792a1;
  font-size: 24rpx;
}

.search-box {
  height: 76rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 8rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  color: #7f8a99;
  background: rgba(255, 255, 255, 0.06);
  font-size: 26rpx;
}

.card {
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.2);
}

.tag {
  min-width: 88rpx;
  height: 52rpx;
  border-radius: 8rpx;
  padding: 0 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #dce3ea;
  background: rgba(255, 255, 255, 0.08);
  font-size: 24rpx;
}

.tag-active {
  color: #fff;
  background: #ff4b48;
}
